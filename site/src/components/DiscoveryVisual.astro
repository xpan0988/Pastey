---
interface Props { aria: string; }
const { aria } = Astro.props;
---
<div class="discovery-visual" aria-label={aria}>
  <div class="discovery-center">
    <div class="discovery-rings" aria-hidden="true"><span></span><span></span><span></span><span></span></div>
    <i class="ph ph-broadcast discovery-core" aria-hidden="true"></i>
    <span class="discovery-device d1"><i class="ph ph-laptop"></i></span>
    <span class="discovery-device d2"><i class="ph ph-device-mobile"></i></span>
    <span class="discovery-device d3"><i class="ph ph-desktop-tower"></i></span>
  </div>
</div>
