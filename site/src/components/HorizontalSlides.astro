---
import SlideProgress from "./SlideProgress.astro";

interface Props {
  labels: readonly string[];
  progressAria: string;
}

const { labels, progressAria } = Astro.props;
---

<div class="horizontal-slides" data-slide-deck>
  <slot />
</div>
<SlideProgress labels={labels} aria={progressAria} />

<script>
  const deck = document.querySelector<HTMLElement>("[data-slide-deck]");
  const slides = deck ? Array.from(deck.querySelectorAll<HTMLElement>(".product-slide")) : [];
  const progress = document.querySelector<HTMLElement>("[data-slide-progress]");
  const dots = progress ? Array.from(progress.querySelectorAll<HTMLButtonElement>("[data-slide-target]")) : [];
  const progressFill = progress?.querySelector<HTMLElement>(".slide-progress-rail i");
  const desktop = window.matchMedia("(min-width: 761px)");
  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
  let activeIndex = 0;

  const setActive = (index: number) => {
    activeIndex = index;
    slides.forEach((slide, slideIndex) => slide.classList.toggle("is-active", slideIndex === index));
    dots.forEach((dot, dotIndex) => {
      if (dotIndex === index) dot.setAttribute("aria-current", "step");
      else dot.removeAttribute("aria-current");
    });
    if (progressFill) progressFill.style.setProperty("--slide-progress", `${((index + 1) / slides.length) * 100}%`);

    document.querySelectorAll<HTMLAnchorElement>(".nav-links a").forEach((link) => {
      const target = new URL(link.href).hash.slice(1);
      const relevantSlide = target === "features" ? "features" : target === "how-it-works" ? "how-it-works" : "";
      link.classList.toggle("is-active", Boolean(relevantSlide) && slides[index]?.id === relevantSlide);
    });
  };

  const goTo = (index: number) => {
    const nextIndex = Math.max(0, Math.min(index, slides.length - 1));
    const slide = slides[nextIndex];
    if (!deck || !slide) return;

    if (desktop.matches) {
      slide.scrollIntoView({ behavior: "auto", block: "nearest", inline: "start" });
    } else {
      slide.scrollIntoView({ behavior: reducedMotion.matches ? "auto" : "smooth", block: "start" });
    }
    setActive(nextIndex);
  };

  dots.forEach((dot) => dot.addEventListener("click", () => goTo(Number(dot.dataset.slideTarget))));

  deck?.addEventListener("wheel", (event) => {
    if (!desktop.matches || Math.abs(event.deltaY) <= Math.abs(event.deltaX)) return;
    event.preventDefault();
    deck.scrollBy({ left: event.deltaY, behavior: "auto" });
    setActive(Math.round(deck.scrollLeft / deck.clientWidth));
  }, { passive: false });

  deck?.addEventListener("scroll", () => {
    if (!desktop.matches) return;
    setActive(Math.round(deck.scrollLeft / deck.clientWidth));
  });

  document.addEventListener("keydown", (event) => {
    if (!desktop.matches || event.altKey || event.ctrlKey || event.metaKey) return;
    if (event.key === "ArrowRight" || event.key === "ArrowDown") {
      event.preventDefault();
      goTo(activeIndex + 1);
    }
    if (event.key === "ArrowLeft" || event.key === "ArrowUp") {
      event.preventDefault();
      goTo(activeIndex - 1);
    }
  });

  document.querySelectorAll<HTMLAnchorElement>('a[href*="#"]').forEach((link) => {
    link.addEventListener("click", (event) => {
      const url = new URL(link.href);
      if (url.pathname !== window.location.pathname) return;
      const index = slides.findIndex((slide) => slide.id === url.hash.slice(1));
      if (index < 0) return;
      event.preventDefault();
      history.replaceState(null, "", url.hash);
      goTo(index);
    });
  });

  if (deck && slides.length) {
    if (!desktop.matches) {
      const observer = new IntersectionObserver((entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
        if (!visible) return;
        setActive(slides.indexOf(visible.target as HTMLElement));
      }, { threshold: [0.55, 0.75] });
      slides.forEach((slide) => observer.observe(slide));
    }

    const hashIndex = slides.findIndex((slide) => slide.id === window.location.hash.slice(1));
    setActive(hashIndex >= 0 ? hashIndex : 0);
    if (hashIndex >= 0) {
      requestAnimationFrame(() => goTo(hashIndex));
      window.setTimeout(() => setActive(hashIndex), 100);
    }
  }
</script>
