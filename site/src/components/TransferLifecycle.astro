---
interface Props { aria: string; labels: readonly string[]; }
const { aria, labels } = Astro.props;
const icons = ["ph-file", "ph-lock-key", "ph-squares-four", "ph-waveform", "ph-download-simple", "ph-sparkle"];
const steps = icons.map((icon, index) => [icon, labels[index]]);
---
<ol class="lifecycle" aria-label={aria}>
  {steps.map(([icon, label], index) => (
    <li class={index === steps.length - 1 ? "clear-step" : ""} style={`--i:${index}`}>
      <span><i class={`ph ${icon}`} aria-hidden="true"></i></span>
      <strong>{label}</strong>
    </li>
  ))}
</ol>
