<div class="echo-panel" aria-label="Nearby devices ready for a local handoff">
  <div class="panel-bar"><span class="status-dot"></span><strong>Nearby Echo</strong><span class="panel-close">×</span></div>
  <div class="echo-stage">
    <article class="device-card">
      <div class="device-pulses" aria-hidden="true"><span></span><span></span><span></span></div>
      <i class="ph ph-laptop device-icon" aria-hidden="true"></i>
      <strong>MacBook Air</strong>
      <small><span class="status-dot green"></span>Nearby device found</small>
    </article>
    <div class="echo-line" aria-hidden="true"><span><i class="ph ph-link"></i></span></div>
    <article class="device-card">
      <div class="device-pulses delayed" aria-hidden="true"><span></span><span></span><span></span></div>
      <i class="ph ph-desktop-tower device-icon" aria-hidden="true"></i>
      <strong>Windows Desktop</strong>
      <small><span class="status-dot green"></span>Ready to handoff</small>
    </article>
  </div>
  <p class="panel-foot"><i class="ph ph-shield-check" aria-hidden="true"></i> Devices connected on your LAN</p>
</div>
