---
interface Props {
  labels: {
    aria: string;
    title: string;
    macbook: string;
    windowsDesktop: string;
    nearbyFound: string;
    readyHandoff: string;
    connected: string;
  };
}
const { labels } = Astro.props;
---
<div class="echo-panel" aria-label={labels.aria}>
  <div class="panel-bar"><span class="status-dot"></span><strong>{labels.title}</strong><span class="panel-close">×</span></div>
  <div class="echo-stage">
    <article class="device-card">
      <div class="device-pulses" aria-hidden="true"><span></span><span></span><span></span></div>
      <i class="ph ph-laptop device-icon" aria-hidden="true"></i>
      <strong>{labels.macbook}</strong>
      <small><span class="status-dot green"></span>{labels.nearbyFound}</small>
    </article>
    <div class="echo-line" aria-hidden="true"><span><i class="ph ph-link"></i></span></div>
    <article class="device-card">
      <div class="device-pulses delayed" aria-hidden="true"><span></span><span></span><span></span></div>
      <i class="ph ph-desktop-tower device-icon" aria-hidden="true"></i>
      <strong>{labels.windowsDesktop}</strong>
      <small><span class="status-dot green"></span>{labels.readyHandoff}</small>
    </article>
  </div>
  <p class="panel-foot"><i class="ph ph-shield-check" aria-hidden="true"></i> {labels.connected}</p>
</div>
