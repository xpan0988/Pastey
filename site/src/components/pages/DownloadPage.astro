---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { links } from "../../data/links";
import type { Locale } from "../../i18n/config";
import type { Dictionary } from "../../i18n";
interface Props { locale: Locale; dictionary: Dictionary; }
const { locale, dictionary: d } = Astro.props;
---
<BaseLayout locale={locale} title={d.seo.downloadTitle} description={d.seo.downloadDescription}>
  <section class="page-hero shell">
    <p class="eyebrow"><span></span> {d.download.eyebrow}</p>
    <h1>{d.download.title}</h1>
    <p>{d.download.description}</p>
    <div class="button-row centered"><a class="button button-primary" href={links.latestRelease}><i class="ph ph-download-simple"></i>{d.common.downloadLatestRelease}</a><a class="button" href={links.releases}>{d.download.allReleases}</a></div>
  </section>
  <section class="download-grid shell">
    <article class="download-card"><i class="ph ph-apple-logo"></i><h2>macOS</h2><p>{d.download.macText}</p><a class="text-link" href={links.latestRelease}>{d.download.getLatest} <i class="ph ph-arrow-right"></i></a></article>
    <article class="download-card"><i class="ph ph-windows-logo"></i><h2>Windows</h2><p>{d.download.windowsText}</p><a class="text-link" href={links.latestRelease}>{d.download.getLatest} <i class="ph ph-arrow-right"></i></a></article>
  </section>
  <aside class="note-card shell"><i class="ph ph-info"></i><div><strong>{d.download.localAccess}</strong><p>{d.download.localAccessText}</p></div></aside>
</BaseLayout>
