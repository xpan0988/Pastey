---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HorizontalSlides from "../HorizontalSlides.astro";
import DeviceEcho from "../DeviceEcho.astro";
import BinaryStream from "../BinaryStream.astro";
import NoCloudPath from "../NoCloudPath.astro";
import TransferLifecycle from "../TransferLifecycle.astro";
import DiscoveryVisual from "../DiscoveryVisual.astro";
import { links } from "../../data/links";
import { localePath, type Locale } from "../../i18n/config";
import type { Dictionary } from "../../i18n";

interface Props { locale: Locale; dictionary: Dictionary; }
const { locale, dictionary: d } = Astro.props;
const v = d.visuals;
const inspectHref = (key: string) => ({
  architecture: localePath(locale, "architecture"),
  changelog: links.changelog,
  validation: links.validation,
  limitations: `${localePath(locale, "architecture")}#boundaries`,
  github: links.github
}[key] ?? links.github);
---

<BaseLayout locale={locale} title={d.seo.title} description={d.seo.description} bodyClass="landing-page" hideFooter>
  <HorizontalSlides labels={d.landing.slideLabels} progressAria={d.landing.slideProgress}>
    <section class="product-slide hero-slide is-active" id="hero" data-slide-index="01">
      <div class="slide-shell shell hero">
        <div class="hero-copy">
          <p class="eyebrow"><span></span> {d.landing.heroEyebrow}</p>
          <h1>{d.landing.heroLead}<br /><em>{d.landing.heroAccent}</em></h1>
          <p class="hero-lede">{d.landing.heroDescription}</p>
          <div class="button-row">
            <a class="button button-primary" href={links.latestRelease}><i class="ph ph-download-simple"></i>{d.common.downloadLatestRelease}</a>
            <a class="button" href={links.github}><i class="ph ph-github-logo"></i>{d.common.viewOnGitHub}</a>
          </div>
          <a class="text-link" href={localePath(locale, "architecture")}>{d.common.readArchitecture} <i class="ph ph-arrow-right"></i></a>
        </div>
        <DeviceEcho labels={{ aria: v.nearbyEchoAria, title: v.nearbyEcho, macbook: v.macbook, windowsDesktop: v.windowsDesktop, nearbyFound: v.nearbyFound, readyHandoff: v.readyHandoff, connected: v.devicesConnected }} />
      </div>
    </section>

    <section class="product-slide" id="features" data-slide-index="02">
      <div class="slide-shell shell slide-layout">
        <div class="slide-copy"><i class="ph ph-folder-open feature-icon"></i><p class="eyebrow"><span></span> 02</p><h2>{d.landing.handoffTitle}</h2><p>{d.landing.handoffText}</p></div>
        <div class="handoff-visual slide-visual">
          <div class="pile-card"><div class="pile-icons"><i class="ph ph-file-pdf"></i><i class="ph ph-file-zip"></i><i class="ph ph-file-image"></i><i class="ph ph-file-video"></i></div><p>{d.landing.pile}</p></div>
          <i class="ph ph-arrow-right handoff-arrow"></i>
          <div class="complete-card"><i class="ph ph-check"></i><p>{d.landing.roomBurned}<br /><span>{d.landing.payloadsCleared}</span></p></div>
        </div>
      </div>
    </section>

    <section class="product-slide" id="how-it-works" data-slide-index="03">
      <div class="slide-shell shell slide-layout">
        <div class="slide-copy"><i class="ph ph-broadcast feature-icon"></i><p class="eyebrow"><span></span> 03</p><h2>{d.landing.nearbyTitle}</h2><p>{d.landing.nearbyText}</p></div>
        <DiscoveryVisual aria={v.discoveryAria} />
      </div>
    </section>

    <section class="product-slide" id="bytes" data-slide-index="04">
      <div class="slide-shell shell slide-layout">
        <div class="slide-copy"><i class="ph ph-code feature-icon"></i><p class="eyebrow"><span></span> 04</p><h2>{d.landing.bytesTitle}</h2><p>{d.landing.bytesText}</p></div>
        <BinaryStream labels={{ aria: v.binaryAria, sender: v.sender, receiver: v.receiver, payloadChunks: v.payloadChunks, ackControl: v.ackControl, binaryPath: v.binaryPath, chunksReceived: v.chunksReceived }} />
      </div>
    </section>

    <section class="product-slide" id="speed" data-slide-index="05">
      <div class="slide-shell shell slide-layout">
        <div class="slide-copy"><i class="ph ph-lightning feature-icon"></i><p class="eyebrow"><span></span> 05</p><h2>{d.landing.speedTitle}</h2><p>{d.landing.speedText}</p><small>{d.landing.speedCaveat}</small></div>
        <NoCloudPath labels={{ cloudPath: v.cloudPath, pasteyPath: v.pasteyPath, deviceA: v.deviceA, deviceB: v.deviceB, upload: v.upload, relay: v.relay, download: v.download, useMostLan: v.useMostLan, observedRange: v.observedRange, capacityAria: v.capacityAria }} />
      </div>
    </section>

    <section class="product-slide" id="lifecycle" data-slide-index="06">
      <div class="slide-shell shell slide-layout">
        <div class="slide-copy"><i class="ph ph-arrows-clockwise feature-icon"></i><p class="eyebrow"><span></span> 06</p><h2>{d.landing.lifecycleTitle}</h2><p>{d.landing.lifecycleText}</p></div>
        <TransferLifecycle aria={v.lifecycleAria} labels={v.lifecycleSteps} />
      </div>
    </section>

    <section class="product-slide" id="inspected" data-slide-index="07">
      <div class="slide-shell shell inspected-slide">
        <div class="slide-copy"><i class="ph ph-shield-check feature-icon"></i><p class="eyebrow"><span></span> 07</p><h2>{d.landing.inspectedTitle}</h2><p>{d.landing.inspectedText}</p></div>
        <div class="inspect-grid">
          {d.landing.inspectCards.map(([icon, title, text, key, action]) => <a class="inspect-card" href={inspectHref(key)}><i class={`ph ${icon}`}></i><strong>{title}</strong><p>{text}</p><span>{action} <i class="ph ph-arrow-right"></i></span></a>)}
        </div>
      </div>
    </section>

    <section class="product-slide final-slide" id="download" data-slide-index="08">
      <div class="slide-shell shell final-cta">
        <p class="eyebrow centered"><span></span> {d.landing.finalEyebrow}</p>
        <h2>{d.landing.finalLead} <em>{d.landing.finalAccent}</em></h2>
        <p>{d.landing.finalText}</p>
        <div class="button-row centered">
          <a class="button button-primary" href={links.latestRelease}><i class="ph ph-download-simple"></i>{d.common.downloadLatestRelease}</a>
          <a class="button" href={links.github}><i class="ph ph-github-logo"></i>{d.common.viewOnGitHub}</a>
        </div>
      </div>
    </section>
  </HorizontalSlides>
</BaseLayout>
