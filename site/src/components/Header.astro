---
import { links } from "../data/links";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import { localePath, type Locale } from "../i18n/config";

interface Props {
  locale: Locale;
  pathname: string;
  copy: Record<string, string>;
}
const { locale, pathname, copy } = Astro.props;
---

<header class="site-header">
  <nav class="nav shell" aria-label={copy.navigation}>
    <a class="brand" href={localePath(locale)} aria-label={copy.pasteyHome}>
      <img src="/favicon.png" alt="" width="30" height="30" />
      <span>Pastey</span>
    </a>
    <div class="nav-links" id="nav-links">
      <a href={`${localePath(locale)}#features`}>{copy.features}</a>
      <a href={`${localePath(locale)}#how-it-works`}>{copy.howItWorks}</a>
      <a href={localePath(locale, "architecture")}>{copy.architecture}</a>
      <a href={localePath(locale, "download")}>{copy.download}</a>
      <a href={links.github}>{copy.github}</a>
    </div>
    <LanguageSwitcher locale={locale} pathname={pathname} label={copy.language} />
    <a class="button button-small button-quiet desktop-download" href={links.latestRelease}>
      <i class="ph ph-download-simple" aria-hidden="true"></i>
      {copy.downloadLatest}
    </a>
    <button class="menu-button" aria-expanded="false" aria-controls="nav-links" aria-label={copy.toggleNavigation}>
      <i class="ph ph-list" aria-hidden="true"></i>
    </button>
  </nav>
</header>

<script>
  const menuButton = document.querySelector<HTMLButtonElement>(".menu-button");
  const navLinks = document.querySelector<HTMLElement>(".nav-links");
  menuButton?.addEventListener("click", () => {
    const expanded = menuButton.getAttribute("aria-expanded") === "true";
    menuButton.setAttribute("aria-expanded", String(!expanded));
    navLinks?.classList.toggle("is-open", !expanded);
  });
  navLinks?.querySelectorAll("a").forEach((link) => link.addEventListener("click", () => {
    menuButton?.setAttribute("aria-expanded", "false");
    navLinks?.classList.remove("is-open");
  }));
</script>
