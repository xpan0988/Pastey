---
import { links } from "../data/links";
import { localePath, type Locale } from "../i18n/config";
interface Props { locale: Locale; copy: Record<string, string>; }
const { locale, copy } = Astro.props;
---

<footer class="footer shell">
  <div>
    <a class="brand" href={localePath(locale)}><img src="/favicon.png" alt="" width="26" height="26" /><span>Pastey</span></a>
    <p>{copy.footerTagline}<br />{copy.footerSubline}</p>
  </div>
  <div class="footer-links">
    <div><strong>{copy.product}</strong><a href={`${localePath(locale)}#features`}>{copy.features}</a><a href={`${localePath(locale)}#how-it-works`}>{copy.howItWorks}</a><a href={localePath(locale, "download")}>{copy.download}</a></div>
    <div><strong>{copy.resources}</strong><a href={links.changelog}>{copy.changelog}</a><a href={links.validation}>{copy.validationNotes}</a><a href={links.github}>{copy.github}</a></div>
  </div>
  <p class="footer-meta">© 2026 Pastey<br />{copy.footerMeta}</p>
</footer>
