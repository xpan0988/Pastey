---
interface Props {
  labels: {
    cloudPath: string;
    pasteyPath: string;
    deviceA: string;
    deviceB: string;
    upload: string;
    relay: string;
    download: string;
    useMostLan: string;
    observedRange: string;
    capacityAria: string;
  };
}
const { labels } = Astro.props;
---
<div class="path-visual">
  <div class="path-row cloud-row">
    <strong>{labels.cloudPath}</strong>
    <div class="path-items">
      <span><i class="ph ph-laptop"></i><small>{labels.deviceA}</small></span><b>→</b>
      <span><i class="ph ph-cloud-arrow-up"></i><small>{labels.upload}</small></span><b>→</b>
      <span><i class="ph ph-cloud"></i><small>{labels.relay}</small></span><b>→</b>
      <span><i class="ph ph-cloud-arrow-down"></i><small>{labels.download}</small></span><b>→</b>
      <span><i class="ph ph-laptop"></i><small>{labels.deviceB}</small></span>
    </div>
  </div>
  <div class="path-row local-row">
    <strong>{labels.pasteyPath}</strong>
    <div class="local-line"><span><i class="ph ph-laptop"></i><small>{labels.deviceA}</small></span><b>LAN</b><span><i class="ph ph-laptop"></i><small>{labels.deviceB}</small></span></div>
  </div>
  <div class="capacity-row">
    <div><strong>{labels.useMostLan}</strong><span>{labels.observedRange}</span></div>
    <div class="capacity-meter" aria-label={labels.capacityAria}>
      <span class="capacity-fill"></span>
      <i>75–80%</i>
    </div>
  </div>
</div>
